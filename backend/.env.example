SPORTSBOT_COMBAT_POSTER_SEARCH_QUERIES=
SPORTSBOT_BROADCAST_SCHEDULE_SEARCH_QUERIES=
SPORTSBOT_F1_SCHEDULE_SEARCH_QUERIES=
SPORTSBOT_FIXTURES_TODAY_SCHEDULE_ENABLED=false
SPORTSBOT_FIXTURES_TODAY_SCHEDULE_TIME=08:00
SPORTSBOT_TV_GUIDE_SCHEDULE_ENABLED=false
SPORTSBOT_TV_GUIDE_SCHEDULE_TIME=08:00
SPORTSBOT_LIVE_NOW_SCHEDULE_ENABLED=false
SPORTSBOT_LIVE_NOW_SCHEDULE_FREQUENCY=everyFiveMinutes
SPORTSBOT_FIXTURE_QUEUE_SCHEDULE_ENABLED=false
SPORTSBOT_FIXTURE_QUEUE_PREFETCH_ENABLED=true
SPORTSBOT_FIXTURE_QUEUE_PREFETCH_TIME=05:00
SPORTSBOT_FIXTURE_QUEUE_ENRICH_ENABLED=true
SPORTSBOT_FIXTURE_QUEUE_ENRICH_FREQUENCY=everyThirtyMinutes
SPORTSBOT_FIXTURE_QUEUE_ENRICH_DAYS=2
SPORTSBOT_FIXTURE_QUEUE_ENRICH_LIMIT=30
SPORTSBOT_FIXTURE_QUEUE_RENDER_ENABLED=true
SPORTSBOT_FIXTURE_QUEUE_RENDER_FREQUENCY=everyTenMinutes
SPORTSBOT_FIXTURE_QUEUE_PUBLISH_ENABLED=true
SPORTSBOT_FIXTURE_QUEUE_PUBLISH_FREQUENCY=everyFiveMinutes
SPORTSBOT_CACHE_LIVE_SCORES=60
SPORTSBOT_CACHE_FIXTURES=900
SPORTSBOT_CACHE_LEAGUE_TABLE=3600
SPORTSBOT_CACHE_TV_GUIDE=1800
SPORTSBOT_CACHE_TEAM=86400
SPORTSBOT_CACHE_PLAYER=86400
SPORTSBOT_CACHE_METADATA=86400
SPORTSBOT_CARDS_ENABLED=true
SPORTSBOT_CARD_WIDTH=1200
SPORTSBOT_CARD_HEIGHT=675
SPORTSBOT_CARD_FONT_REGULAR=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
SPORTSBOT_CARD_FONT_BOLD=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
