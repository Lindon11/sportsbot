# Shared secret for license activation callback HMAC (set to a strong random value in production)
LICENSE_CALLBACK_SECRET=
# LaravelCP Environment Configuration
# -------------------------------------
# TIP: For easy setup, use the web installer at: https://your-domain.com/install
# The installer will configure this file automatically!
# -------------------------------------

APP_NAME=LaravelCP
APP_ENV=local
APP_KEY=base64:placeholder
# ⚠️ PRODUCTION: Set to false — true exposes full stack traces to users
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173
APP_SCHEDULER_HTTP_TOKEN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravelcp
DB_USERNAME=laravelcp
DB_PASSWORD=laravelcp

SESSION_DRIVER=database
SESSION_LIFETIME=120
# ⚠️ PRODUCTION: Set to true — encrypts session data at rest
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# ⚠️ PRODUCTION: Use 'redis' for better queue performance
QUEUE_CONNECTION=database

# ⚠️ PRODUCTION: Use 'redis' — database cache bottlenecks under game load
CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# CORS & Sanctum Configuration (IMPORTANT FOR PRODUCTION)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5175
CORS_SUPPORTS_CREDENTIALS=false
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:5175

# ⚠️ PRODUCTION: Change to 'smtp' or 'mailgun' — 'log' only writes to storage/logs
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailgun Configuration (for production)
# Set MAIL_MAILER=mailgun to use Mailgun
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sports Bot plugin
# Keep native sending/scheduling disabled while the legacy bridge is still live.
SPORTSBOT_ENABLED=true
SPORTSBOT_SEND_MESSAGES=false
SPORTSBOT_SCHEDULE_ENABLED=false
SPORTSBOT_SCHEDULE_FREQUENCY=everyTwoMinutes
SPORTSBOT_PROVIDER=thesportsdb
SPORTSBOT_THESPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v2/json
SPORTSBOT_THESPORTSDB_API_KEY=
SPORTSBOT_HTTP_TIMEOUT=20
SPORTSBOT_HTTP_CONNECT_TIMEOUT=10
SPORTSBOT_LIVE_SCORE_CACHE_TTL=75
SPORTSBOT_TELEGRAM_BOT_TOKEN=
SPORTSBOT_TELEGRAM_CHAT_ID=
SPORTSBOT_TELEGRAM_MESSAGE_THREAD_ID=
SPORTSBOT_TELEGRAM_EXTRA_CHAT_IDS=
SPORTSBOT_TELEGRAM_PARSE_MODE=HTML
SPORTSBOT_TELEGRAM_DISABLE_NOTIFICATION=false
SPORTSBOT_TELEGRAM_WEBHOOK_ENABLED=false
SPORTSBOT_TELEGRAM_WEBHOOK_SECRET=
SPORTSBOT_DISCORD_ENABLED=false
SPORTSBOT_DISCORD_WEBHOOK_URL=
SPORTSBOT_DISCORD_USERNAME=SportsBot
SPORTSBOT_DISCORD_AVATAR_URL=
SPORTSBOT_ENABLED_SPORTS=Soccer,Basketball,Baseball,American Football,Tennis,Fighting,Rugby,Cricket,Motorsport,Ice Hockey,Golf
SPORTSBOT_ALLOWED_LEAGUE_IDS=
SPORTSBOT_MAX_LIVE_MATCHES_PER_RUN=75
SPORTSBOT_TV_ENABLED=true
SPORTSBOT_TV_CHANNELS=
SPORTSBOT_TV_SPORTS=Soccer,Basketball,Baseball,MMA,Tennis,Rugby
SPORTSBOT_TV_LOOKAHEAD_HOURS=24
SPORTSBOT_TV_MAX_EVENTS_PER_CHANNEL=20
SPORTSBOT_TV_GUIDE_MAX_PER_CHANNEL=8
SPORTSBOT_TV_GUIDE_SHOW_EMPTY_CHANNELS=false
SPORTSBOT_TV_CACHE_TTL=900
SPORTSBOT_SCRAPERS_ENABLED=true
# Search is optional. Use a public search endpoint you are allowed to call, for example a self-hosted SearxNG JSON/HTML endpoint.
# The scraper replaces {query} with the URL-encoded event search phrase.
SPORTSBOT_SCRAPER_SEARCH_ENABLED=false
SPORTSBOT_SCRAPER_SEARCH_URLS=
SPORTSBOT_SCRAPER_SEARCH_MAX_RESULTS=5
SPORTSBOT_SCRAPER_AUTO_USE_CONFIDENCE=0.9
