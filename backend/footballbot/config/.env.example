TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_CHAT_ID=-1001234567890
THESPORTSDB_API_KEY=replace_me

# Optional: Separate chat for error alerts (defaults to TELEGRAM_CHAT_ID)
TELEGRAM_ERROR_CHAT_ID=-1001234567890

# Optional: Additional chat IDs for multi-group support (comma-separated)
TELEGRAM_EXTRA_CHAT_IDS=-1009876543210,-1005555555555

# Optional: Telegram forum topic routing by sport. The admin panel can manage this as rows.
TELEGRAM_MESSAGE_THREAD_ID=
BOT_TELEGRAM_ROUTES_JSON={"Soccer":[{"chat_id":"-1001234567890","thread_id":10}],"Rugby":[{"chat_id":"-1001234567890","thread_id":12}]}
TELEGRAM_WEBHOOK_ENABLED=false
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Optional
BOT_TIMEZONE=Europe/London
BOT_DEBUG=false
BOT_FONT_REGULAR=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
BOT_FONT_BOLD=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

# Daily match card (sent once per day at the configured time)
BOT_SEND_DAILY_CARD=true
BOT_DAILY_CARD_TIME=08:00
BOT_DAILY_CARD_SEND_IMAGE=true

# Smart matchday burst cards (fixtures, live, TV, results, tomorrow)
BOT_CARD_BURSTS_ENABLED=true
BOT_CARD_ROUTE_MODE=smart
BOT_CARD_TYPES_ENABLED=kickoff_soon,live_now,results,tv_now
BOT_CONTENT_PACKS_ENABLED=live_now,kickoff_soon,results,tv_now
BOT_CARD_BURST_MIN_FIXTURES=3
BOT_CARD_BURST_MIN_LIVE=2
BOT_CARD_BURST_MIN_RESULTS=3
BOT_CARD_BURST_COOLDOWN_MINUTES=60
BOT_CARD_MAX_ITEMS_PER_TYPE=4
BOT_CARD_MAX_PAGES_PER_RUN=12
BOT_CARD_MAX_SENDS_PER_RUN=12

# Kick-off reminder (sent N minutes before a match starts)
BOT_SEND_KICKOFF_REMINDER=true
BOT_KICKOFF_REMINDER_MINUTES=10
BOT_SEND_MATCH_STARTS=false
BOT_SEND_SCORE_UPDATES=false
BOT_SEND_PERIOD_CHANGES=false

# Created automatically by the private admin UI.
# BOT_ADMIN_PASSWORD_HASH=
